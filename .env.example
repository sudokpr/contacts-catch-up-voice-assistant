export VAPI_API_KEY=          # Secret API key — server-side only, never expose to browser
export VAPI_PUBLIC_KEY=       # Public key — safe for browser; Vapi dashboard → Account → API Keys
export VAPI_ASSISTANT_ID=
export VAPI_PHONE_NUMBER_ID=
export VAPI_SIP_TRUNK_ID=

export QDRANT_API_KEY=
export QDRANT_ENDPOINT=

# Embedding provider — choose one mode:
#
# Mode 1 (default): Qdrant cloud inference — free, no external API key needed
#   EMBEDDING_PROVIDER=qdrant
#   EMBEDDING_MODEL=sentence-transformers/all-minilm-l6-v2
#   EMBEDDING_VECTOR_SIZE=384
#
# Mode 2: External provider (Gemini or any OpenAI-compatible endpoint)
#   EMBEDDING_PROVIDER=external
#   EMBEDDING_API_KEY=<your-key>
#   EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/  # Gemini (auto-detected)
#                   or http://localhost:11434/v1                           # Ollama/nomic
#   EMBEDDING_MODEL=gemini-embedding-001    # or nomic-embed-text
#   EMBEDDING_VECTOR_SIZE=3072              # or 768 for nomic
export EMBEDDING_PROVIDER=qdrant
export EMBEDDING_MODEL=sentence-transformers/all-minilm-l6-v2
export EMBEDDING_VECTOR_SIZE=384
export EMBEDDING_API_KEY=
export EMBEDDING_BASE_URL=

# Auth — set to a strong random string to protect the dashboard on public deployments
# If empty, auth is disabled (safe for local dev)
export APP_SECRET_KEY=

export APP_BASE=              # Public base URL, e.g. https://xyz.ngrok-free.dev
export USER_NAME=             # Your name — used in call prompts
export DATABASE_URL=          # SQLite path (default: contacts.db); set to /data/contacts.db for Docker
export SCHEDULER_ENABLED=true # Set to false to disable all automated calls
